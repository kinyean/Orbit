# Template for the local dev secrets consumed by the docker compose stacks.
#
# Setup on a fresh checkout:
#   cp .env.example .env      # then edit the values below
# Docker Compose auto-loads .env for ${VAR} interpolation. .env is gitignored;
# THIS file (.env.example) is committed and must contain NO real secrets.

# --- Postgres (base stack: docker-compose.yml) ---
# The db_data volume is initialised with this on first `up`. If you change it
# later you must wipe the volume (docker compose down -v) — that deletes all data.
POSTGRES_PASSWORD=change-me
DB_PASSWORD=change-me

# --- Keycloak master admin (OIDC overlay: docker-compose.oidc.yml) ---
# Log into the admin console at https://<host>:8443/admin/ with these.
# Use a strong value (e.g. `openssl rand -base64 18`).
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me

# --- Seed app users (OIDC overlay) ---
# Applied to the realm's demo users after import (kcadm), so no password is
# ever committed. Fine to keep simple for local dev.
MAYA_PASSWORD=change-me
FRANK_PASSWORD=change-me
GITA_PASSWORD=change-me
DEMO_PASSWORD=change-me
