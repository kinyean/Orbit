# Get a free token at https://ion.cesium.com/signup
VITE_CESIUM_ION_TOKEN=your_cesium_ion_access_token_here

# Where the Vite dev server proxies /api/* to. Set by docker-compose to
# http://backend:8080 (the backend service on the docker network). Override
# for purely-local frontend dev where the backend runs in a container with a
# published port, e.g. http://localhost:8081.
#
# Only used by the Vite dev server (Node side). The browser never sees this.
PROXY_TARGET=http://localhost:8081
